root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,h,S}]
indent_style = tab
indent_size = 8
max_line_length = 80

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab

[*.nix]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
